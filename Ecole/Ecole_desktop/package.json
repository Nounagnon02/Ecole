{
  "name": "ecole-desktop",
  "version": "1.0.0",
  "description": "École — Application Desktop de Gestion Scolaire",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "com.ecole.desktop",
    "productName": "École",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "icon.png"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education",
      "icon": "icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
